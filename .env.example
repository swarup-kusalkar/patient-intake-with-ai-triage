# =============================================================
# Patient Intake System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# =============================================================

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/patient_intake

# OpenAI (or compatible) API key
LLM_API_KEY=your-api-key-here

# LLM model to use — smallest model that supports structured JSON output
LLM_MODEL=gpt-4o-mini

# LLM request timeout in seconds
LLM_TIMEOUT_SECONDS=15

# Max tokens for LLM response (output schema is tiny — keep this low)
LLM_MAX_TOKENS=150

# Comma-separated list of allowed CORS origins — NEVER use *
CORS_ORIGINS_RAW=http://localhost:3000

# Rate limit for POST /api/v1/triage/analyze (slowapi format)
TRIAGE_RATE_LIMIT=10/minute

# Debug mode — false in production
DEBUG=false
