# =============================================================
# Patient Intake System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it is gitignored.
# =============================================================

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/patient_intake

# =============================================================
# LLM Configuration — Hybrid: Groq (Primary) + Gemini (Fallback)
# =============================================================
# Primary provider: "groq" or "gemini"
# Recommended: Use Groq as primary (fastest, 30 RPM free), Gemini as fallback
LLM_PRIMARY_PROVIDER=groq

# -------------------------------------------------------------
# Groq LPU (Primary — Fastest, Best for Demo)
# -------------------------------------------------------------
# Get your API key from: https://console.groq.com/keys
# Free tier: 30 RPM, 10K requests/day
# Models: llama-3.1-70b-versatile (balanced) or llama-3.2-3b-preview (fastest)
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama-3.1-70b-versatile
GROQ_TIMEOUT_SECONDS=15
GROQ_MAX_TOKENS=150

# -------------------------------------------------------------
# Google Gemini Flash (Fallback — Reliable Backup)
# -------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
# Free tier: 15 RPM, 1M tokens/month
# Models: gemini-2.0-flash-exp (latest) or gemini-1.5-flash (stable)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp
GEMINI_MAX_TOKENS=150

# =============================================================
# CORS — comma-separated list of allowed origins (NEVER use *)
# =============================================================
CORS_ORIGINS_RAW=http://localhost:3000

# =============================================================
# Rate Limiting for POST /api/v1/triage/analyze (slowapi format)
# =============================================================
TRIAGE_RATE_LIMIT=10/minute

# =============================================================
# Debug Mode — set to false in production
# =============================================================
DEBUG=false